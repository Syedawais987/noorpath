generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  PARENT
  TEACHER
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  REVIEWED
  REDO
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime? @map("email_verified")
  passwordHash      String?   @map("password_hash")
  image             String?
  role              Role      @default(STUDENT)
  name              String
  phone             String?
  timezone          String    @default("UTC")
  preferredLanguage String    @default("en") @map("preferred_language")
  whatsappOptedIn   Boolean   @default(false) @map("whatsapp_opted_in")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  accounts           Account[]
  studentProfile     StudentProfile?
  enrollmentRequest  EnrollmentRequest?
  teacherSessions    Session[]       @relation("TeacherSessions")
  studentSessions Session[]       @relation("StudentSessions")
  assignments     Assignment[]    @relation("StudentAssignments")
  createdAssignments Assignment[] @relation("TeacherAssignments")
  invoices        Invoice[]
  notifications   Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
}

model EnrollmentRequest {
  id                String           @id @default(cuid())
  userId            String           @unique @map("user_id")
  relationship      String
  location          String?
  preferredSchedule String?          @map("preferred_schedule")
  status            EnrollmentStatus @default(PENDING)
  adminMessage      String?          @map("admin_message")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("enrollment_requests")
}

model StudentProfile {
  id             String  @id @default(cuid())
  userId         String  @unique @map("user_id")
  age            Int?
  learningGoal   String? @map("learning_goal")
  currentLevel   String? @map("current_level")
  linkedParentId String? @map("linked_parent_id")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressEntries ProgressEntry[]

  @@map("student_profiles")
}

model Session {
  id           String        @id @default(cuid())
  teacherId    String        @map("teacher_id")
  studentId    String        @map("student_id")
  startTime    DateTime      @map("start_time")
  endTime      DateTime      @map("end_time")
  status       SessionStatus @default(SCHEDULED)
  dailyRoomUrl String?       @map("daily_room_url")
  recordingUrl String?       @map("recording_url")
  createdAt    DateTime      @default(now()) @map("created_at")

  teacher     User          @relation("TeacherSessions", fields: [teacherId], references: [id])
  student     User          @relation("StudentSessions", fields: [studentId], references: [id])
  sessionNote SessionNote?

  @@map("sessions")
}

model SessionNote {
  id               String           @id @default(cuid())
  sessionId        String           @unique @map("session_id")
  content          String?
  studentFeedback  String?          @map("student_feedback")
  tajweedScore     Int?             @map("tajweed_score")
  attendanceStatus AttendanceStatus @default(PRESENT) @map("attendance_status")
  createdAt        DateTime         @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_notes")
}

model ProgressEntry {
  id           String   @id @default(cuid())
  studentId    String   @map("student_id")
  surahName    String?  @map("surah_name")
  paraNumber   Int?     @map("para_number")
  lessonNumber Int?     @map("lesson_number")
  date         DateTime @default(now())
  notes        String?

  studentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("progress_entries")
}

model Assignment {
  id            String           @id @default(cuid())
  studentId     String           @map("student_id")
  teacherId     String           @map("teacher_id")
  title         String
  description   String?
  dueDate       DateTime?        @map("due_date")
  attachmentUrl String?          @map("attachment_url")
  status        AssignmentStatus @default(PENDING)
  feedback      String?
  submissionUrl String?          @map("submission_url")
  createdAt     DateTime         @default(now()) @map("created_at")

  student User @relation("StudentAssignments", fields: [studentId], references: [id])
  teacher User @relation("TeacherAssignments", fields: [teacherId], references: [id])

  @@map("assignments")
}

model Availability {
  id        String  @id @default(cuid())
  dayOfWeek Int     @map("day_of_week")
  startTime String  @map("start_time")
  endTime   String  @map("end_time")
  isActive  Boolean @default(true) @map("is_active")

  @@map("availabilities")
}

model Invoice {
  id            String        @id @default(cuid())
  studentId     String        @map("student_id")
  amount        Float
  currency      String        @default("PKR")
  dueDate       DateTime      @map("due_date")
  paidAt        DateTime?     @map("paid_at")
  status        InvoiceStatus @default(PENDING)
  paymentMethod String?       @map("payment_method")
  receiptUrl    String?       @map("receipt_url")
  createdAt     DateTime      @default(now()) @map("created_at")

  student User @relation(fields: [studentId], references: [id])

  @@map("invoices")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String
  message   String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
